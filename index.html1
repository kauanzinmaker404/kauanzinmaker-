<!DOCTYPE html>
<html>
<head>
  <title>Kauanzin</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      text-align: center;
      color: white;
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: black; /* AGORA VAI FICAR PRETO */
      overflow: hidden;
    }

    /* FUNDO COM NOME */
    body::before {
      content: "@kauanzinmaker @kauanzinmaker @kauanzinmaker @kauanzinmaker";
      position: fixed;
      width: 200%;
      height: 200%;
      font-size: 60px;
      color: rgba(0, 255, 204, 0.05);
      transform: rotate(-30deg);
      animation: moveBg 20s linear infinite;
      z-index: -1;
    }

    @keyframes moveBg {
      from { transform: rotate(-30deg) translateY(0); }
      to { transform: rotate(-30deg) translateY(-400px); }
    }

    .container {
      text-align: center;
    }

    img {
      width: 150px;
      height: 150px;
      object-fit: cover;
      border-radius: 50%;
      border: 4px solid #00ffcc;
      box-shadow: 0 0 30px #00ffcc;
      margin-bottom: 20px;
    }

    h1 {
      font-size: 55px;
      text-shadow: 0 0 20px #00ffcc;
      margin-bottom: 30px;
    }

    a {
      display: block;
      margin: 15px auto;
      padding: 20px;
      width: 280px;
      background: #00ffcc;
      color: black;
      text-decoration: none;
      border-radius: 12px;
      font-size: 20px;
      font-weight: bold;
      box-shadow: 0 0 15px #00ffcc;
      transition: 0.3s;
    }

    a:hover {
      transform: scale(1.1);
      background: #00ccaa;
    }
  </style>
</head>

<body>

  <div class="container">

    <!-- COLOCA SUA FOTO AQUI -->
    <img src=https://imgur.com/a/SMiJGeq>

    <h1>@kauanzinmaker</h1>

    <a href="https://tiktok.com/@oliveirazz7_">🔥 TikTok</a>
    <a href="https://instagram.com/kauanzinmaker">📸 Instagram</a>

  </div>

</body>
</html>
