<!DOCTYPE html>
<html>
<head>
  <title>Kauanzin</title>

  <style>
    body {
      margin: 0;
      font-family: Arial;
      background: black;
      color: white;
      overflow: hidden;
      display: flex;
      justify-content: center;
      align-items: center;
      height: 100vh;
    }

    /* PARTÍCULAS */
    body::after {
      content: "";
      position: fixed;
      width: 100%;
      height: 100%;
      background: radial-gradient(#00ffcc 1px, transparent 1px);
      background-size: 40px 40px;
      animation: moveParticles 10s linear infinite;
      opacity: 0.2;
      z-index: -1;
    }

    @keyframes moveParticles {
      from { transform: translateY(0); }
      to { transform: translateY(-100px); }
    }

    .container {
      text-align: center;
    }

    /* LOGO ? */
    .logo {
      width: 150px;
      height: 150px;
      border-radius: 50%;
      border: 3px solid #00ffcc;
      display: flex;
      justify-content: center;
      align-items: center;
      font-size: 60px;
      font-weight: bold;
      color: #00ffcc;
      margin: 0 auto 20px;
      box-shadow: 0 0 25px #00ffcc;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0% { box-shadow: 0 0 10px #00ffcc; }
      50% { box-shadow: 0 0 40px #00ffcc; }
      100% { box-shadow: 0 0 10px #00ffcc; }
    }

    /* NOME GLITCH */
    h1 {
      font-size: 60px;
      position: relative;
      animation: glitch 1s infinite;
    }

    @keyframes glitch {
      0% { text-shadow: 2px 2px #00ffcc; }
      20% { text-shadow: -2px -2px #ff00ff; }
      40% { text-shadow: 2px -2px #00ffcc; }
      60% { text-shadow: -2px 2px #ff00ff; }
      80% { text-shadow: 2px 2px #00ffcc; }
      100% { text-shadow: 0 0 10px #00ffcc; }
    }

    a {
      display: block;
      margin: 20px auto;
      padding: 20px;
      width: 280px;
      background: transparent;
      border: 2px solid #00ffcc;
      color: #00ffcc;
      text-decoration: none;
      border-radius: 12px;
      font-size: 20px;
      font-weight: bold;
      transition: 0.3s;
      box-shadow: 0 0 10px #00ffcc;
    }

    a:hover {
      background: #00ffcc;
      color: black;
      transform: scale(1.1);
      box-shadow: 0 0 25px #00ffcc;
    }

  </style>
</head>

<body>

  <div class="container">

    <div class="logo">?</div>

    <h1>@kauanzinmaker</h1>

    <a href="https://tiktok.com/@oliveirazz7_">🔥 TikTok</a>
    <a href="https://instagram.com/kauanzinmaker">📸 Instagram</a>

  </div>

</body>
</html>
